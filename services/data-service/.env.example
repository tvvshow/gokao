# 服务配置
PORT=8082
GIN_MODE=debug

# 数据库配置
DATABASE_URL=postgres://postgres:password@localhost:5432/gaokao_data?sslmode=disable

# Redis配置
REDIS_URL=localhost:6379
REDIS_PASSWORD=
REDIS_DB=1

# Elasticsearch配置
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Swagger配置
ENABLE_SWAGGER=true

# 缓存配置
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=5m

# 性能配置
MAX_PAGE_SIZE=100
DEFAULT_PAGE_SIZE=20
QUERY_TIMEOUT=30s

# C++算法引擎配置
ALGORITHM_ENGINE_ENABLED=false
ALGORITHM_ENGINE_ADDR=localhost:50051

# 审计配置
ENABLE_AUDIT=true
AUDIT_LOG_LEVEL=info