# device_fingerprint.pc.in - pkg-config file for DeviceFingerprint library
# This file is auto-generated by CMake

prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@

Name: DeviceFingerprint
Description: High-performance cross-platform device fingerprint collection module
Version: @PROJECT_VERSION@
URL: https://github.com/gaokao-system/device-fingerprint

# Compiler flags
Cflags: -I${includedir}
Cflags.private: -std=c++@CMAKE_CXX_STANDARD@

# Linker flags
Libs: -L${libdir} -ldevice_fingerprint
Libs.private: -lssl -lcrypto -lpthread

# Dependencies
Requires: openssl >= 1.1.0
Requires.private: 

