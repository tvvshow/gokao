prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: gaokaohub-license
Description: GaoKaoHub License Management Library
Version: @PROJECT_VERSION@
Requires: openssl jsoncpp sqlite3
Libs: -L${libdir} -lgaokaohub_license
Cflags: -I${includedir}/gaokaohub/license
