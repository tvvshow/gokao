# 高考志愿填报系统 - 开发环境配置文件
# 复制此文件为 .env 并根据需要修改配置

# 项目配置
COMPOSE_PROJECT_NAME=gaokao-dev
VERSION=dev

# 数据库配置
POSTGRES_DB=gaokao_dev
POSTGRES_USER=gaokao_user
POSTGRES_PASSWORD=gaokao_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 应用配置
JWT_SECRET=dev-jwt-secret-key-change-in-production
DEBUG=true
LOG_LEVEL=debug
GIN_MODE=debug

# API Gateway配置
API_GATEWAY_PORT=8080
ENABLE_SWAGGER=1
USER_SERVICE_URL=http://user-service:8081
CPP_MODULE_URL=http://cpp-modules:8082

# User Service配置
USER_SERVICE_PORT=8081

# C++ Modules配置
CPP_MODULE_PORT=8082
CPP_MODULE_PATH=/app

# 开发工具端口
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@gaokao.dev
PGADMIN_PASSWORD=admin123

REDIS_COMMANDER_PORT=8081

# 监控配置
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin123
PROMETHEUS_PORT=9090

# 性能配置
DB_MAX_CONNECTIONS=20
DB_MAX_IDLE_CONNECTIONS=10
REDIS_MAX_CONNECTIONS=100

# 安全配置（开发环境可以宽松一些）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
SESSION_TIMEOUT=3600
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# 热重载配置
ENABLE_HOT_RELOAD=true
WATCH_PATHS=./services

# 调试配置
ENABLE_DEBUG_ENDPOINTS=true
DEBUG_PORT_API_GATEWAY=2345
DEBUG_PORT_USER_SERVICE=2346

# 测试配置
ENABLE_TEST_DATA=true
TEST_DATA_PATH=./test-data

# 日志配置
LOG_FORMAT=text
LOG_OUTPUT=stdout
ENABLE_REQUEST_LOGGING=true

# Docker配置
RESTART_POLICY=unless-stopped
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# 开发者工具
ENABLE_PPROF=true
ENABLE_METRICS=true
METRICS_PORT=9091

# 推荐分析 LLM 配置（OpenAI 兼容协议）
# 真实 BASE_URL / API_KEY 仅写入未提交的 .env 文件，禁止入库；
# 服务启动日志只打 provider+model，不打 base_url，不暴露给前端 / system/status。
LLM_ENABLED=false
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_TIMEOUT=15s
LLM_FALLBACK_ENABLED=true
# LLM_SYSTEM_PROMPT 留空将使用代码内置默认