# 高考志愿填报系统 - 生产环境配置文件
# 复制此文件为 .env 并修改所有密码和密钥

# 项目配置
COMPOSE_PROJECT_NAME=gaokao-prod
VERSION=latest

# 数据库配置 - 请修改密码！
POSTGRES_DB=gaokao_prod
POSTGRES_USER=gaokao_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis配置 - 请修改密码！
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# 应用配置 - 请修改密钥！
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_KEY_AT_LEAST_32_CHARS
DEBUG=false
LOG_LEVEL=info
GIN_MODE=release

# API Gateway配置
API_GATEWAY_PORT=8080
ENABLE_SWAGGER=0
USER_SERVICE_URL=http://user-service:8081
CPP_MODULE_URL=http://cpp-modules:8082

# User Service配置
USER_SERVICE_PORT=8081

# C++ Modules配置
CPP_MODULE_PORT=8082
CPP_MODULE_PATH=/app

# SSL/TLS配置
ENABLE_HTTPS=true
TLS_CERT_FILE=/run/secrets/tls_cert
TLS_KEY_FILE=/run/secrets/tls_key
FORCE_HTTPS=true

# 监控配置 - 请修改密码！
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD
PROMETHEUS_RETENTION_DAYS=30

# 性能配置
DB_MAX_CONNECTIONS=100
DB_MAX_IDLE_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30s
REDIS_MAX_CONNECTIONS=500
REDIS_CONNECTION_TIMEOUT=5s

# 安全配置
CORS_ALLOWED_ORIGINS=https://yourdomain.com
SESSION_TIMEOUT=1800
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
ENABLE_RATE_LIMITING=true

# 防护配置
ENABLE_CSRF_PROTECTION=true
ENABLE_XSS_PROTECTION=true
ENABLE_CONTENT_TYPE_NOSNIFF=true
ENABLE_FRAME_OPTIONS=true
ENABLE_HSTS=true

# 缓存配置
ENABLE_REDIS_CLUSTERING=false
REDIS_CACHE_TTL=3600
ENABLE_RESPONSE_CACHING=true

# 数据库优化
DB_STATEMENT_TIMEOUT=30s
DB_IDLE_TIMEOUT=5m
ENABLE_DB_QUERY_LOGGING=false

# 日志配置
LOG_FORMAT=json
LOG_OUTPUT=file
LOG_FILE_PATH=/var/log/gaokao
LOG_MAX_SIZE=100MB
LOG_MAX_FILES=10
ENABLE_REQUEST_LOGGING=false
ENABLE_AUDIT_LOGGING=true

# 监控和告警
ENABLE_METRICS=true
METRICS_PORT=9091
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=3

# 备份配置
ENABLE_AUTO_BACKUP=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backup

# 容器资源限制
POSTGRES_MEMORY_LIMIT=2g
POSTGRES_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=512m
REDIS_CPU_LIMIT=0.5
API_GATEWAY_MEMORY_LIMIT=512m
API_GATEWAY_CPU_LIMIT=0.5
USER_SERVICE_MEMORY_LIMIT=512m
USER_SERVICE_CPU_LIMIT=0.5
CPP_MODULES_MEMORY_LIMIT=512m
CPP_MODULES_CPU_LIMIT=0.5

# Docker配置
RESTART_POLICY=unless-stopped
DOCKER_NETWORK_DRIVER=bridge
ENABLE_DOCKER_LOGGING=true

# 域名和网络配置
DOMAIN_NAME=yourdomain.com
ENABLE_WWW_REDIRECT=true
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024

# 防火墙和网络安全
ALLOWED_IPS=0.0.0.0/0
BLOCK_COUNTRIES=
ENABLE_DDOS_PROTECTION=true

# 文件上传限制
MAX_UPLOAD_SIZE=10MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# 用户会话配置
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict

# API限制
API_REQUEST_SIZE_LIMIT=1MB
API_TIMEOUT=30s
ENABLE_API_VERSIONING=true

# 错误处理
ENABLE_ERROR_REPORTING=true
ERROR_REPORTING_URL=https://errors.yourdomain.com
ENABLE_STACK_TRACES=false

# 维护模式
ENABLE_MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=系统维护中，请稍后访问

# 第三方服务
ENABLE_ANALYTICS=true
ANALYTICS_ID=
ENABLE_CDN=false
CDN_URL=