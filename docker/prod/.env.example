# 高考志愿填报系统 — 生产环境变量样板
# 用法：cp docker/prod/.env.example docker/prod/.env，按需修改非默认值
# Secret 类（密码 / 私钥 / TLS）一律走 Docker secrets，详见 docker/prod/SECRETS.md

# ── 项目元信息 ───────────────────────────────────────
COMPOSE_PROJECT_NAME=gaokao-prod
VERSION=latest

# ── 数据库 ───────────────────────────────────────────
# 密码走 secret: docker/prod/secrets/postgres_password.txt
POSTGRES_DB=gaokao_prod
POSTGRES_USER=gaokao_user

# ── Redis ────────────────────────────────────────────
# 密码走 secret: docker/prod/secrets/redis_password.txt

# ── 应用通用 ─────────────────────────────────────────
LOG_LEVEL=info
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=60

# ── 推荐 / LLM 增强（可选） ──────────────────────────
RECOMMENDATION_LLM_ENABLED=false
RECOMMENDATION_LLM_PROVIDER=openai-compatible
RECOMMENDATION_LLM_BASE_URL=https://api.openai.com/v1
# API key 走 secret: docker/prod/secrets/llm_api_key.txt
RECOMMENDATION_LLM_MODEL=gpt-4o-mini
RECOMMENDATION_LLM_TIMEOUT=20s
RECOMMENDATION_LLM_MAX_TOKENS=800
RECOMMENDATION_LLM_TEMPERATURE=0.3
RECOMMENDATION_LLM_FALLBACK_ENABLED=true
ALGORITHM_TYPE=hybrid

# ── 支付适配器（可选，缺失则 adapter 自动跳过） ─────
# 商户号公开可入 env；私钥 / API key 走 secret
ALIPAY_APP_ID=
WECHAT_MCH_ID=

# ── 前端构建参数 ─────────────────────────────────────
# 部署到独立 API 域名时改为绝对 URL；同域反代保持 /api
VITE_API_BASE_URL=/api

# ── 域名 ─────────────────────────────────────────────
# nginx server_name 默认为 _ 通配，正式部署改为真实域名
DOMAIN_NAME=yourdomain.com

# ── 监控 ─────────────────────────────────────────────
PROMETHEUS_RETENTION_DAYS=30
# Grafana admin 密码走 secret: docker/prod/secrets/grafana_admin_password.txt

# ── 数据导入 ─────────────────────────────────────────
# 仅在初始化批量导入时开 true，常态保持 false 避免冷启动延迟
DATA_IMPORT_ENABLED=false
